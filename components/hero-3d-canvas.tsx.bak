'use client';

import { useRef, useState, useEffect } from 'react';
import { Canvas, useFrame } from '@react-three/fiber';
import type { Mesh, Points } from 'three';

// ═══════════════════════════════════════════════════════════════════════════
// ANIMATED CRYSTAL ICOSAHEDRON
// ═══════════════════════════════════════════════════════════════════════════

function CrystalIcosahedron({ mouseY }: { mouseY: number }) {
  const meshRef = useRef<Mesh>(null);
  const floatOffset = useRef(0);

  useFrame((_, delta) => {
    if (!meshRef.current) return;
    meshRef.current.rotation.y += delta * 0.15;
    floatOffset.current += delta * 1.5;
    meshRef.current.position.y = Math.sin(floatOffset.current) * 0.15;
    const targetX = mouseY * 0.3;
    meshRef.current.rotation.x += (targetX - meshRef.current.rotation.x) * 0.05;
  });

  return (
    <mesh ref={meshRef} scale={2.2}>
      <icosahedronGeometry args={[1, 0]} />
      <meshPhysicalMaterial
        transmission={0.95}
        roughness={0.05}
        thickness={1.5}
        ior={1.5}
        color="#FFD700"
        attenuationColor="#FFA500"
        attenuationDistance={0.5}
        transparent
        metalness={0.1}
        clearcoat={1}
        clearcoatRoughness={0}
        envMapIntensity={2}
      />
    </mesh>
  );
}

// ═══════════════════════════════════════════════════════════════════════════
// PARTICLE FIELD
// ═══════════════════════════════════════════════════════════════════════════

function ParticleField() {
  const pointsRef = useRef<Points>(null);
  const particleCount = 150;

  const positions = useRef<Float32Array | null>(null);
  if (!positions.current) {
    positions.current = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount; i++) {
      const radius = 3 + Math.random() * 8;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      positions.current[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
      positions.current[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
      positions.current[i * 3 + 2] = radius * Math.cos(phi);
    }
  }

  useFrame((state) => {
    if (!pointsRef.current) return;
    pointsRef.current.rotation.y = state.clock.elapsedTime * 0.02;
    pointsRef.current.rotation.x = Math.sin(state.clock.elapsedTime * 0.01) * 0.1;
  });

  return (
    <points ref={pointsRef}>
      <bufferGeometry>
        <bufferAttribute
          attach="attributes-position"
          count={particleCount}
          array={positions.current}
          itemSize={3}
        />
      </bufferGeometry>
      <pointsMaterial size={0.08} color="#FFD700" transparent opacity={0.8} sizeAttenuation />
    </points>
  );
}

// ═══════════════════════════════════════════════════════════════════════════
// FLOATING GEOMETRIES
// ═══════════════════════════════════════════════════════════════════════════

function FloatingGeometries() {
  const geo1 = useRef<Mesh>(null);
  const geo2 = useRef<Mesh>(null);
  const geo3 = useRef<Mesh>(null);

  useFrame((state) => {
    const t = state.clock.getElapsedTime();
    if (geo1.current) {
      geo1.current.position.x = Math.sin(t * 0.3) * 4 - 4;
      geo1.current.position.y = Math.cos(t * 0.4) * 1.5 + 1;
      geo1.current.rotation.x = t * 0.2;
      geo1.current.rotation.y = t * 0.3;
    }
    if (geo2.current) {
      geo2.current.position.x = Math.cos(t * 0.25) * 3 + 4;
      geo2.current.position.y = Math.sin(t * 0.35) * 1.2 - 0.5;
      geo2.current.rotation.z = t * 0.25;
    }
    if (geo3.current) {
      geo3.current.position.x = Math.sin(t * 0.2) * 2;
      geo3.current.position.y = Math.cos(t * 0.3) * 0.8 - 2.5;
      geo3.current.rotation.y = t * 0.15;
    }
  });

  return (
    <>
      <mesh ref={geo1} scale={0.35}>
        <octahedronGeometry args={[1, 0]} />
        <meshStandardMaterial color="#FFD700" metalness={0.9} roughness={0.1} emissive="#B8860B" emissiveIntensity={0.2} />
      </mesh>
      <mesh ref={geo2} scale={0.3}>
        <tetrahedronGeometry args={[1, 0]} />
        <meshStandardMaterial color="#FFA500" metalness={0.85} roughness={0.15} emissive="#996515" emissiveIntensity={0.15} />
      </mesh>
      <mesh ref={geo3} scale={0.25}>
        <dodecahedronGeometry args={[1, 0]} />
        <meshStandardMaterial color="#DAA520" metalness={0.8} roughness={0.2} emissive="#7A5012" emissiveIntensity={0.1} />
      </mesh>
    </>
  );
}

// ═══════════════════════════════════════════════════════════════════════════
// MAIN CANVAS COMPONENT
// ═══════════════════════════════════════════════════════════════════════════

interface Props {
  mousePosition: { x: number; y: number };
}

function ThreeCanvas({ mousePosition }: Props) {
  return (
    <Canvas
      camera={{ position: [0, 0, 8], fov: 45 }}
      gl={{ antialias: true, alpha: true, powerPreference: 'high-performance' }}
      dpr={[1, 1.5]}
      style={{ background: 'transparent' }}
    >
      <CrystalIcosahedron mouseY={mousePosition.y} />
      <ParticleField />
      <FloatingGeometries />
      <ambientLight intensity={0.4} />
      <directionalLight position={[10, 10, 5]} intensity={1.5} color="#FFFAF0" />
      <directionalLight position={[-10, -10, -5]} intensity={0.8} color="#FFD700" />
      <pointLight position={[0, 8, 0]} intensity={1} color="#FFA500" />
      <pointLight position={[-5, -5, 5]} intensity={0.5} color="#FFD700" />
    </Canvas>
  );
}

export default ThreeCanvas;
